{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "^/(.*\\.(js|css|map|json|ico|png|svg|webp|jpg|jpeg|gif|woff2?|ttf|eot))$",
      "dest": "/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "/index.html"
    }
  ]
}
